{
  "rewrites": [
    {
      "source": "/((?!assets/|robots.txt|sitemap.xml|logo.png|profile.jpeg|certs/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
